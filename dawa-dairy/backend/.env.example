# Copy this file to .env and fill in real values before running the server.

# Port the API server listens on
PORT=4000

# Long random string used to sign login tokens. Generate one with:
# node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=replace_this_with_a_long_random_string

# Your Google Gemini API key (from https://aistudio.google.com/apikey)
# Used server-side only for prescription OCR/extraction — never sent to the browser.
GEMINI_API_KEY=your_actual_gemini_api_key_here

# Optional: override the Gemini model used for extraction. Defaults to gemini-2.5-flash.
# GEMINI_MODEL=gemini-2.5-flash

# Where the frontend will run, for CORS. Adjust if you serve it on a different port.
CORS_ORIGIN=http://localhost:5500
